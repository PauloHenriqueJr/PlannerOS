# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Hotmart (token configurado em: Hotmart > Developer Tools > Webhooks)
# ATENÇÃO: era HOTMART_HOTTTOk (typo triple-T) — corrigido para HOTMART_HOTTOK
HOTMART_HOTTOK=your_hottok_here

# Gemini (usado server-side em /api/ai/* — nunca expor no frontend)
GEMINI_API_KEY=your_gemini_key_here

# Firebase Admin (escolha uma das opções abaixo)
# Opção 1: path para service_account.json
# GOOGLE_APPLICATION_CREDENTIALS=./service_account.json
# Opção 2: JSON inline como string
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Opção 3: JSON em base64
# FIREBASE_SERVICE_ACCOUNT_BASE64=base64encodedstring

# Servidor
PORT=3000
